class Solution:
    def myPow(self, x: float, n: int) -> float:
        ans=1.0
        temp=n
        if n<0:
            n=-n
        while n>0:
            if n%2==1:
                ans=ans*x
                n=n-1
            else:
                x=x*x
                n=n//2
        if temp<0:
            return 1/ans
        return ans
